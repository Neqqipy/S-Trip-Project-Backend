# ═══════════════════════════════════════════════════════════════════════════════
# 🔑 S-TRIP BACKEND - ENVIRONMENT VARIABLES TEMPLATE
# ═══════════════════════════════════════════════════════════════════════════════
#
# HƯỚNG DẪN:
# 1. Copy file này: cp .env.example .env
# 2. Điền các giá trị vào file .env (đừng commit .env!)
# 3. Khởi động: python main.py
#
# ⚠️  KHÔNG SHARE các keys này công khai
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# 🔐 FLASK & SERVER CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Secret key cho Flask sessions (tạo random 32 bytes)
# Dùng lệnh: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_random_secret_key_here_32_bytes

# Environment mode
# development = debug mode (auto-reload), production = no debug
FLASK_ENV=development

# HTTPS flag (true nếu chạy trên Codespaces/Deploy, false nếu localhost)
HTTPS=false

# ═══════════════════════════════════════════════════════════════════════════════
# 🌐 FRONTEND CONFIGURATION (CORS)
# ═══════════════════════════════════════════════════════════════════════════════

# Frontend URL(s) - cách nhau bằng dấu phẩy nếu nhiều
# Dev: http://localhost:3000
# Codespaces: https://your-username-3000.app.github.dev
# Production: https://yourdomain.com
FRONTEND_URL=http://localhost:3000

# Backend URL (dùng cho share links, OG tags)
BACKEND_URL=http://localhost:5000

# ═══════════════════════════════════════════════════════════════════════════════
# 🤖 AI & SEARCH APIs
# ═══════════════════════════════════════════════════════════════════════════════

# Google Gemini API Key
# Lấy tại: https://ai.google.dev → Get API Key
# Hỗ trợ: AI chat, intent recognition, recommendation
GEMINI_API_KEY=AIzaSy_your_gemini_key_here

# SerpAPI Key (Google Search, Maps, Local Business)
# Lấy tại: https://serpapi.com/dashboard
# Hỗ trợ: Tìm chuyến bay, khách sạn, hoạt động, reviews, ảnh
SERPAPI_KEY=your_serpapi_key_here

# Google Maps Embed API Key
# Lấy tại: https://console.cloud.google.com → APIs & Services → Credentials
# Hỗ trợ: Nhúng bản đồ (iframe), Static Maps
GOOGLE_MAPS_API_KEY=AIzaSy_your_maps_key_here

# OpenWeather API Key (thời tiết)
# Lấy tại: https://openweathermap.org/api → API keys
# Tùy chọn - không cần nếu dùng SerpAPI weather
OPENWEATHER_KEY=your_openweather_key_here

# ═══════════════════════════════════════════════════════════════════════════════
# 💾 SUPABASE (Database & Auth)
# ═══════════════════════════════════════════════════════════════════════════════

# Supabase Project URL
# Lấy tại: https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co

# Supabase Service Role Key (KHÔNG phải anon key!)
# Lấy tại: Project Settings → API → service_role secret
# ⚠️  RIÊNG TƯ - KHÔNG share hoặc commit
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...your_service_role_key_here

# ═══════════════════════════════════════════════════════════════════════════════
# 🔓 GOOGLE OAUTH (Đăng nhập)
# ═══════════════════════════════════════════════════════════════════════════════

# Google OAuth 2.0 Client ID
# Lấy tại: https://console.cloud.google.com → Credentials → OAuth 2.0 Client ID
# Type: Web application
# Authorized redirect URIs: http://localhost:5000/auth/callback
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com

# Google OAuth 2.0 Client Secret
# Lấy tại: Project settings → Client secret
# ⚠️  RIÊNG TƯ - KHÔNG share
GOOGLE_CLIENT_SECRET=GOCSPX_your_client_secret_here

# ═══════════════════════════════════════════════════════════════════════════════
# 📧 EMAIL CONFIGURATION (tùy chọn)
# ═══════════════════════════════════════════════════════════════════════════════

# Gmail hoặc email service khác (để gửi reset password, notifications)
# Dùng Gmail App Password (không password chính)
# Lấy tại: myaccount.google.com → Security → App passwords
MAIL_EMAIL=your_email@gmail.com

# App Password (Gmail) hoặc password email
# ⚠️  KHÔNG dùng password Gmail chính, dùng App Password
MAIL_PASSWORD=your_app_password_here

# SMTP Server (Gmail = smtp.gmail.com)
MAIL_SMTP_SERVER=smtp.gmail.com

# SMTP Port (Gmail = 587 hoặc 465)
MAIL_SMTP_PORT=587

# ═══════════════════════════════════════════════════════════════════════════════
# 🎯 APPLICATION SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

# Base URL cho image proxying
API_BASE_URL=http://localhost:5000

# Debug mode (development only)
DEBUG=false

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════════════════════
# 💡 QUICK CHECKLIST
# ═══════════════════════════════════════════════════════════════════════════════
#
# ✅ Required Keys (cần để chạy):
#    - SECRET_KEY (tạo random)
#    - GEMINI_API_KEY
#    - SERPAPI_KEY
#    - SUPABASE_URL
#    - SUPABASE_SERVICE_ROLE_KEY
#
# ⚠️  Optional (tùy chọn):
#    - OPENWEATHER_KEY (nếu không dùng SerpAPI)
#    - GOOGLE_MAPS_API_KEY (nếu không cần map embed)
#    - GOOGLE_CLIENT_ID/SECRET (nếu không cần OAuth)
#    - MAIL_* (nếu không cần gửi email)
#
# 🚀 Deployment (Codespaces):
#    - Đặt HTTPS=true
#    - FRONTEND_URL=https://your-username-3000.app.github.dev
#
# 📚 Xem thêm hướng dẫn tại: README.md
# ═══════════════════════════════════════════════════════════════════════════════
